rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Verification Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Individual Collection Match Rules for users/{uid}/
    match /users/{userId} {
      // Validate user is modifying their own document profile
      allow get, write: if isOwner(userId) && isValidId(userId);

      // System settings
      match /profile/settings {
        allow read, write: if isOwner(userId);
      }

      // Workout session records
      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId) && isValidId(sessionId);
      }

      // Body weight logs
      match /bodyweight/{dateStr} {
        allow read, write: if isOwner(userId) && dateStr.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
      }

      // Body measurements logs
      match /measurements/{dateStr} {
        allow read, write: if isOwner(userId) && dateStr.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
      }

      // Custom Exercises log library
      match /customExercises/{exerciseId} {
        allow read, write: if isOwner(userId) && isValidId(exerciseId);
      }

      // Weekly planned routings
      match /weeklyPlan/plan {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
